// ─────────────────────────────────────────────────────────────────────────────
// PRISMA SCHEMA — Gestion Commerciale ERP/POS
// DB : PostgreSQL sur serveur dédié Hostinger (connexion SSL obligatoire)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS  ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  CAISSIER
  DISTRIBUTEUR
}

enum StatutVente {
  COMPLETEE
  ANNULEE
  REMBOURSEE
}

enum ModePaiement {
  ESPECES
  CARTE
  VIREMENT
  CHEQUE
  MIXTE
  CREDIT
}

enum StatutPaiement {
  PAYE
  EN_ATTENTE
}

enum TypeMouvement {
  ENTREE
  SORTIE_VENTE
  SORTIE_MANUELLE
  CORRECTION
  INVENTAIRE
  RETOUR
}

enum ConditionRetour {
  NEUF
  BON_ETAT
  ABIME
}

enum TypeEcriture {
  RECETTE_VENTE
  REMBOURSEMENT
  DEPENSE
  CORRECTION
}

enum TypeDocument {
  FACTURE
  RECU
  RAPPORT
  EXPORT_CLIENT
}

// ─── UTILISATEURS ────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  nom          String
  prenom       String
  role         Role      @default(CAISSIER)
  actif        Boolean   @default(true)
  lastLoginAt  DateTime? @map("last_login_at")
  lastLoginIp  String?   @map("last_login_ip")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  ventes              Vente[]
  auditLogs           AuditLog[]
  notes               Note[]
  demandesEnvoyees    DemandeApprobation[] @relation("DemandesDemandeur")
  retours             RetourProduit[]      @relation("RetoursAuteur")

  @@map("users")
}

// ─── ENTREPRISE ──────────────────────────────────────────────────────────────

model Entreprise {
  id                      String   @id @default(cuid())
  nom                     String
  siret                   String?
  tvaIntracommunautaire   String?  @map("tva_intracommunautaire")
  adresse                 String
  codePostal              String   @map("code_postal")
  ville                   String
  telephone               String?
  email                   String?
  siteWeb                 String?  @map("site_web")
  logoUrl                 String?  @map("logo_url")
  tauxTVADefaut           Float    @default(20.0) @map("taux_tva_defaut")
  mentionsLegales         String?  @map("mentions_legales")
  conditionsGenerales     String?  @map("conditions_generales")
  piedPageFacture         String?  @map("pied_page_facture")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("entreprise")
}

// ─── CLIENTS ─────────────────────────────────────────────────────────────────

model Client {
  id               String    @id @default(cuid())
  nom              String
  prenom           String?
  email            String?   @unique
  telephone        String?
  adresse          String?
  codePostal       String?   @map("code_postal")
  ville            String?
  categorieId      String?   @map("categorie_id")
  totalAchats      Float     @default(0) @map("total_achats")
  dernierAchat     DateTime? @map("dernier_achat")
  consentementRGPD Boolean   @default(false) @map("consentement_rgpd")
  consentementDate DateTime? @map("consentement_date")
  anonymiseLe      DateTime? @map("anonymise_le")    // RGPD : date d'anonymisation
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  categorie CategorieClient? @relation(fields: [categorieId], references: [id])
  ventes    Vente[]

  @@map("clients")
}

model CategorieClient {
  id      String  @id @default(cuid())
  nom     String  @unique
  remise  Float   @default(0)     // % de remise automatique

  clients Client[]

  @@map("categories_clients")
}

// ─── PRODUITS & STOCK ────────────────────────────────────────────────────────

model Categorie {
  id       String    @id @default(cuid())
  nom      String    @unique
  produits Produit[]

  @@map("categories")
}

model Produit {
  id               String    @id @default(cuid())
  nom              String
  description      String?
  codeBarres       String?   @unique @map("code_barres")
  categorieId      String?   @map("categorie_id")
  prixVente        Float     @map("prix_vente")
  prixGros         Float?    @map("prix_gros")
  qtePrixGros      Int?      @map("qte_prix_gros")
  prixAchat        Float     @default(0) @map("prix_achat")
  tauxTVA          Float     @default(0) @map("taux_tva")
  stockActuel      Int       @default(0) @map("stock_actuel")
  stockMinimum     Int       @default(5) @map("stock_minimum")
  actif            Boolean   @default(true)
  deletedAt        DateTime? @map("deleted_at")         // soft delete — null = actif
  imageUrl         String?   @map("image_url")
  couleur          String?                              // Code hex ex: #C17F24 (couleur principale)
  poids            String?                              // ex: "50g", "100g"
  dateAcquisition  DateTime? @map("date_acquisition")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  categorie       Categorie?        @relation(fields: [categorieId], references: [id])
  variantes       VarianteProduit[]
  mouvementsStock MouvementStock[]
  lignesVente     LigneVente[]
  lignesRetour    LigneRetour[]

  @@map("produits")
}

model VarianteProduit {
  id            String  @id @default(cuid())
  produitId     String  @map("produit_id")
  couleur       String
  codeBarres    String? @unique @map("code_barres")
  stockActuel   Int     @default(0) @map("stock_actuel")
  stockMinimum  Int     @default(0) @map("stock_minimum")

  produit       Produit        @relation(fields: [produitId], references: [id], onDelete: Cascade)
  lignesVente   LigneVente[]
  lignesRetour  LigneRetour[]
  mouvements    MouvementStock[]

  @@map("variantes_produits")
}

model MouvementStock {
  id          String        @id @default(cuid())
  produitId   String        @map("produit_id")
  varianteId  String?       @map("variante_id")
  type        TypeMouvement
  quantite    Int
  stockAvant  Int           @map("stock_avant")
  stockApres  Int           @map("stock_apres")
  motif       String?
  venteId     String?       @map("vente_id")
  userId      String        @map("user_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  produit  Produit          @relation(fields: [produitId], references: [id])
  variante VarianteProduit? @relation(fields: [varianteId], references: [id])

  @@map("mouvements_stock")
}

// ─── VENTES ──────────────────────────────────────────────────────────────────

model Vente {
  id             String      @id @default(cuid())
  numero         String      @unique                         // VTE-2024-00001
  clientId       String?     @map("client_id")
  userId         String      @map("user_id")
  statut         StatutVente @default(COMPLETEE)
  sousTotal      Float       @map("sous_total")
  montantTVA     Float       @map("montant_tva")
  remiseGlobale  Float       @default(0) @map("remise_globale")
  total          Float
  modePaiement   ModePaiement   @default(ESPECES)   @map("mode_paiement")
  statutPaiement StatutPaiement @default(PAYE)      @map("statut_paiement")
  montantPaye    Float?                              @map("montant_paye")    // montant déjà payé (paiement partiel)
  dateFacture    DateTime?                           @map("date_facture")
  dateEcheance   DateTime?                           @map("date_echeance")
  notes          String?
  factureUrl     String?     @map("facture_url")
  synchedAt      DateTime?   @map("synched_at")
  offlineId      String?     @map("offline_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  client                 Client?              @relation(fields: [clientId], references: [id])
  vendeur                User                 @relation(fields: [userId], references: [id])
  lignes                 LigneVente[]
  ecrituresFinancieres   EcritureFinanciere[]
  documents              Document[]
  demandes               DemandeApprobation[]
  retours                RetourProduit[]

  @@map("ventes")
}

model LigneVente {
  id           String  @id @default(cuid())
  venteId      String  @map("vente_id")
  produitId    String  @map("produit_id")
  varianteId   String? @map("variante_id")
  quantite     Int
  prixUnitaire Float   @map("prix_unitaire")
  remise       Float   @default(0)
  tauxTVA      Float   @map("taux_tva")
  total        Float

  vente    Vente            @relation(fields: [venteId], references: [id], onDelete: Cascade)
  produit  Produit          @relation(fields: [produitId], references: [id])
  variante VarianteProduit? @relation(fields: [varianteId], references: [id])

  @@map("lignes_ventes")
}

// ─── FINANCES ─────────────────────────────────────────────────────────────────

// Append-only : pas d'UPDATE ni de DELETE pour garantir l'intégrité comptable
model EcritureFinanciere {
  id          String       @id @default(cuid())
  venteId     String?      @map("vente_id")
  type        TypeEcriture
  montant     Float
  description String
  date        DateTime     @default(now())
  metadata    Json?        // Données supplémentaires (ex: mode de paiement, caissier)

  vente Vente? @relation(fields: [venteId], references: [id])

  @@map("ecritures_financieres")
}

// ─── DOCUMENTS ───────────────────────────────────────────────────────────────

model Document {
  id            String       @id @default(cuid())
  type          TypeDocument
  nom           String
  entityId      String       @map("entity_id")
  entityType    String       @map("entity_type")          // "vente" | "client" | etc.
  cheminFichier String       @map("chemin_fichier")       // Chemin absolu sur Hostinger
  tokenAcces    String       @unique @default(cuid()) @map("token_acces")
  tokenExpire   DateTime     @map("token_expire")         // URL signée temporaire
  envoiEmail    Boolean      @default(false) @map("envoi_email")
  emailDestinataire String?  @map("email_destinataire")
  createdAt     DateTime     @default(now()) @map("created_at")

  // entityId est polymorphique (vente | client) — jointures en code applicatif
  // La relation explicite venteId est maintenue séparément pour les factures
  venteId String? @map("vente_id")
  vente   Vente?  @relation(fields: [venteId], references: [id])

  @@map("documents")
}

// ─── NOTES INTERNES ──────────────────────────────────────────────────────────

model Note {
  id          String   @id @default(cuid())
  contenu     String
  entityId    String   @map("entity_id")
  entityType  String   @map("entity_type")               // "client" | "produit" | "vente"
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // entityId est une clé polymorphique (client | produit | vente)
  // Les jointures sont faites en code applicatif, pas via Prisma
  auteur User @relation(fields: [userId], references: [id])

  @@map("notes")
}

// ─── AUDIT LOGS ──────────────────────────────────────────────────────────────

// Append-only : chaque action sensible est journalisée avec IP + horodatage
model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  @map("user_id")
  action      String                                      // ex: "vente.created", "stock.updated"
  entityId    String?  @map("entity_id")
  entityType  String?  @map("entity_type")
  details     Json?                                       // Données avant/après modification
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ─── DEMANDES D'APPROBATION ───────────────────────────────────────────────────

enum TypeDemande {
  ANNULATION
  REMBOURSEMENT
  MODIFICATION
}

enum StatutDemande {
  EN_ATTENTE
  APPROUVEE
  REJETEE
}

model DemandeApprobation {
  id          String        @id @default(cuid())
  type        TypeDemande
  venteId     String        @map("vente_id")
  demandeurId String        @map("demandeur_id")
  statut      StatutDemande @default(EN_ATTENTE)
  motif       String
  reponse     String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  vente     Vente @relation(fields: [venteId], references: [id])
  demandeur User  @relation("DemandesDemandeur", fields: [demandeurId], references: [id])

  @@map("demandes_approbation")
}

// ─── RETOURS PRODUITS ─────────────────────────────────────────────────────────

model RetourProduit {
  id          String   @id @default(cuid())
  venteId     String   @map("vente_id")
  userId      String   @map("user_id")
  motif       String
  montantRembourse Float @default(0) @map("montant_rembourse")
  createdAt   DateTime @default(now()) @map("created_at")

  vente    Vente              @relation(fields: [venteId], references: [id])
  auteur   User               @relation("RetoursAuteur", fields: [userId], references: [id])
  lignes   LigneRetour[]

  @@map("retours_produits")
}

model LigneRetour {
  id           String          @id @default(cuid())
  retourId     String          @map("retour_id")
  produitId    String          @map("produit_id")
  varianteId   String?         @map("variante_id")
  quantite     Int
  prixUnitaire Float           @map("prix_unitaire")
  condition    ConditionRetour @default(BON_ETAT)

  retour   RetourProduit    @relation(fields: [retourId], references: [id], onDelete: Cascade)
  produit  Produit          @relation(fields: [produitId], references: [id])
  variante VarianteProduit? @relation(fields: [varianteId], references: [id])

  @@map("lignes_retour")
}
